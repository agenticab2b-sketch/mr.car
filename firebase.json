{
  "hosting": {
    "public": ".",
    "cleanUrls": true,
    "trailingSlash": false,
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "optimize.py",
      "README.md",
      "GEMINI.md",
      "implementation_plan.md.resolved",
      "functions/**"
    ],
    "headers": [],
    "redirects": [
      {
        "source": "/homepage.html",
        "destination": "/ru/",
        "type": 301
      },
      {
        "source": "/teenused",
        "destination": "/teenused.html",
        "type": 301
      },
      {
        "source": "/hinnad",
        "destination": "/prices.html",
        "type": 301
      },
      {
        "source": "/privaatsuspoliitika",
        "destination": "/privaatsus/",
        "type": 301
      },
      {
        "source": "/jata-paring",
        "destination": "/",
        "type": 301
      },
      {
        "source": "/silindripea-remont",
        "destination": "/services/mootoriremont",
        "type": 301
      },
      {
        "source": "/teenused/kaubiku-remont-hooldus-koplis",
        "destination": "/services/autoremont",
        "type": 301
      },
      {
        "source": "/teenused/autoremont-hooldus-koplis",
        "destination": "/services/autoremont",
        "type": 301
      },
      {
        "source": "/teenused/mootori-diagnostika",
        "destination": "/services/hooldus-diagnostika",
        "type": 301
      },
      {
        "source": "/teenused/mootori-remont-ja-vahetus",
        "destination": "/services/mootoriremont",
        "type": 301
      },
      {
        "source": "/teenused/mootori-ja-kaigukasti-remont",
        "destination": "/services/mootoriremont",
        "type": 301
      },
      {
        "source": "/services/webasto-remont",
        "destination": "/services/webasto-diagnostika",
        "type": 301
      },
      {
        "source": "/teenused/webasto-remont",
        "destination": "/services/webasto-diagnostika",
        "type": 301
      },
      {
        "source": "/teenused/webasto-remont/webasto-vead-ja-symptomid",
        "destination": "/services/webasto-sumptomid",
        "type": 301
      }
    ],
    "rewrites": []
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "disallowLegacyRuntimeConfig": true,
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ]
    }
  ]
}