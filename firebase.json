{
  "hosting": {
    "public": ".",
    "cleanUrls": true,
    "trailingSlash": false,
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "optimize.py",
      "README.md",
      "GEMINI.md",
      "implementation_plan.md.resolved",
      "functions/**"
    ],
    "headers": [
      {
        "source": "**/*.@(html|css|js|png|jpg|jpeg|gif|svg|webp|avif|ico|xml|json)",
        "headers": [
          {
            "key": "X-Robots-Tag",
            "value": "noindex, nofollow, noarchive"
          }
        ]
      }
    ],
    "redirects": [
      {
        "source": "/homepage.html",
        "destination": "/ru/",
        "type": 301
      },
      {
        "source": "/services/webasto-remont",
        "destination": "/services/webasto-diagnostika",
        "type": 301
      },
      {
        "source": "/teenused/webasto-remont",
        "destination": "/services/webasto-diagnostika",
        "type": 301
      },
      {
        "source": "/teenused/webasto-remont/webasto-vead-ja-symptomid",
        "destination": "/services/webasto-sumptomid",
        "type": 301
      }
    ],
    "rewrites": []
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "disallowLegacyRuntimeConfig": true,
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ]
    }
  ]
}